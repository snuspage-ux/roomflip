generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Generation {
  id        String   @id @default(cuid())
  userId    String   @default("anonymous")
  inputUrl  String
  outputUrl String
  style     String
  room      String
  createdAt DateTime @default(now())
}

model RateLimit {
  id        String   @id
  count     Int      @default(0)
  date      String
}
