generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Generation {
  id        String   @id @default(cuid())
  userId    String   @default("anonymous")
  inputUrl  String
  outputUrl String
  style     String
  room      String
  createdAt DateTime @default(now())
}

model RateLimit {
  id        String   @id
  count     Int      @default(0)
  date      String
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  credits   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  Session[]
  purchases Purchase[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Purchase {
  id         String   @id @default(cuid())
  userId     String
  email      String
  amount     Float
  credits    Int
  method     String
  status     String
  paypalOrderId String?
  nowpaymentsInvoiceId String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}
